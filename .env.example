# توکن بات تلگرام (از @BotFather دریافت کنید)
TELEGRAM_BOT_TOKEN=

# کلید API سرویس هوش مصنوعی (Groq، DeepSeek، OpenRouter، Cerebras یا هر provider سازگار با OpenAI)
AI_API_KEY=

# آدرس پایه API — سازگار با فرمت OpenAI، برای سوییچ بعدی به هر provider دیگه فقط همین رو عوض کنید
# نمونه Groq (سریع‌ترین در تست ما): https://api.groq.com/openai/v1
# نمونه DeepSeek: https://api.deepseek.com
# نمونه OpenRouter (دارای مدل‌های رایگان): https://openrouter.ai/api/v1
AI_BASE_URL=https://api.groq.com/openai/v1

# نام مدل مورد استفاده
# نمونه Groq: openai/gpt-oss-120b
# نمونه DeepSeek: deepseek-chat
AI_MODEL=openai/gpt-oss-120b

# مدلی که برای تحلیل عکس‌های ارسالی (مثلاً عکس دفترچه) استفاده می‌شود
AI_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# مدلی که برای تبدیل پیام‌های صوتی به متن استفاده می‌شود
AI_AUDIO_MODEL=whisper-large-v3-turbo

# آیدی عددی تلگرام کوچ (شما) — برای دسترسی به دستورات مدیریتی کوچ
# با فرستادن /start به بات و بررسی لاگ، یا از باتی مثل @userinfobot می‌تونید پیدا کنید
COACH_TELEGRAM_ID=

# مسیر فایل دیتابیس SQLite
DATABASE_PATH=konkur_coach.db

# زمان‌بندی ۵ نوبت روزانه‌ی agent کوچینگ (فرمت ۲۴ ساعته)
# نوبت ۱: لیزر کوچینگ صبحگاهی (۶ سوال)
MORNING_LASER_HOUR=8
MORNING_LASER_MINUTE=0
# نوبت‌های ۲ تا ۴: پیام انگیزشی + دکمه‌ی وضعیت سریع
MIDDAY_1_HOUR=11
MIDDAY_1_MINUTE=0
MIDDAY_2_HOUR=14
MIDDAY_2_MINUTE=0
MIDDAY_3_HOUR=17
MIDDAY_3_MINUTE=0
# نوبت ۵: گزارش‌گیری شبانه و ارزیابی کامل (۱۰ سوال)
EVENING_REPORT_HOUR=22
EVENING_REPORT_MINUTE=0

# ساعت بررسی روزانه‌ی عدم‌فعالیت دانش‌آموز (یادآوری هوشمند)
ENGAGEMENT_CHECK_HOUR=12
ENGAGEMENT_CHECK_MINUTE=0

# روز و ساعت برنامه‌ریزی هفتگی تعاملی (روز: 0=یکشنبه، 1=دوشنبه ... 4=پنج‌شنبه، 5=جمعه، 6=شنبه)
WEEKLY_PLANNING_DAY=4
WEEKLY_PLANNING_HOUR=19
WEEKLY_PLANNING_MINUTE=0

# روز و ساعت دایجست هفتگی خودکار برای کوچ و والدین
WEEKLY_DIGEST_DAY=5
WEEKLY_DIGEST_HOUR=20
WEEKLY_DIGEST_MINUTE=0

# ساعت یادآوری شمارش‌معکوس امتحان (در صورت فعال بودن /exam_mode)
EXAM_COUNTDOWN_HOUR=9
EXAM_COUNTDOWN_MINUTE=0

# ساعت مرور روزانه‌ی فلش‌کارت‌های سررسیدشده
FLASHCARD_REVIEW_HOUR=16
FLASHCARD_REVIEW_MINUTE=0

# تاریخ کنکور سراسری (اختیاری) — اگه ست بشه، شمارش‌معکوس عمومی برای همه‌ی دانش‌آموزها فعال می‌شه
KONKUR_EXAM_DATE=

# منطقه زمانی برای زمان‌بندی نوبت‌ها
TIMEZONE=Asia/Tehran

# تعداد پیام‌های اخیر مکالمه که به‌عنوان context به AI فرستاده می‌شود
CHAT_HISTORY_LIMIT=6

# سطح لاگ‌گیری: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
